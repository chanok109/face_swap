<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- ป้องกันการเข้าถึง data/ โดยตรง -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="data" />
        </hiddenSegments>
      </requestFiltering>
    </security>
    <!-- ปิด directory browsing -->
    <directoryBrowse enabled="false" />
    <!-- Static content caching -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
    </staticContent>
  </system.webServer>
</configuration>
